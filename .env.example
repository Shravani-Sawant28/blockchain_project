# ──────────────────────────────────────────────
#  MembershipNFT Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit your actual .env to Git!
# ──────────────────────────────────────────────

# ── Deployer wallet ────────────────────────────
# Your wallet private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# ── RPC Endpoints ─────────────────────────────
# Get these from Alchemy (https://alchemy.com) or Infura (https://infura.io)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Etherscan API Keys (for contract verification) ─
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ── Frontend (populated after deployment) ──────
NEXT_PUBLIC_MEMBERSHIP_CONTRACT_ADDRESS=
