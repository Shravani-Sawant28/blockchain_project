# ──────────────────────────────────────────────
#  MembershipNFT Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit your actual .env to Git!
# ──────────────────────────────────────────────

# ── Deployer wallet ────────────────────────────
# Optional for localhost scripts that require explicit signer
PRIVATE_KEY=

# ── Localhost Hardhat RPC ─────────────────────
LOCALHOST_RPC_URL=http://127.0.0.1:8545

# ── Frontend (populated after local deployment) ──────
NEXT_PUBLIC_MEMBERSHIP_NFT_ADDRESS=
