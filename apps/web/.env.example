# Environment Variables
# Copy this file to .env and fill in the values

# Deployed ERC721 NFT address
NEXT_PUBLIC_NFT_ADDRESS=

# Membership NFT (ethers.js) — deployed `MembershipNFT` contract address
NEXT_PUBLIC_MEMBERSHIP_NFT_ADDRESS=

# URL of the ERC721 deployment API
ERC721_DEPLOYMENT_API_URL=http://localhost:4001

# Local JSON-RPC endpoint (Hardhat node)
NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545

# Optional legacy name accepted by app code
NEXT_PUBLIC_MEMBERSHIP_CONTRACT_ADDRESS=