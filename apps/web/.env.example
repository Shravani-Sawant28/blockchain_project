# Environment Variables
# Copy this file to .env and fill in the values

# Deployed ERC721 NFT address
NEXT_PUBLIC_NFT_ADDRESS=

# URL of the ERC721 deployment API
ERC721_DEPLOYMENT_API_URL=http://localhost:4001

# WalletConnect Cloud project ID (https://cloud.walletconnect.com). Optional for local dev:
# if unset, the app uses RainbowKit's placeholder which maps to a demo projectId.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=My DApp