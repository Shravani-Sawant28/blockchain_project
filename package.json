{
  "name": "membership-nft-hardhat",
  "version": "1.0.0",
  "description": "Hardhat environment for MembershipNFT smart contract",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy-membership.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy-membership.js --network sepolia",
    "deploy:mumbai": "hardhat run scripts/deploy-membership.js --network mumbai",
    "verify:sepolia": "hardhat verify --network sepolia",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
